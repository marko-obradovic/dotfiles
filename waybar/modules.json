{

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    // "format": "< %g >",
    // "format_focused" : "< %g в—Џ >",
    "format-icons": {
      "1": "п„ ",
      "2": "п‰©"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true,
    "format": "<span color=\"#24273a\" style=\"italic\">{}</span>"
  },
  "tray": {
    // "icon-size": 14,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
 "months": "<span color='#fabd2f'><b>{}</b></span>",
 "days": "<span color='#ebdbb2'><b>{}</b></span>",
 "weeks": "<span color='#fabd2f'><b>W{}</b></span>",
 "weekdays": "<span color='#ebdbb2'><b>{}</b></span>",
 "today": "<span background='#3c3836' color='#fabd2f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b   |   %I:%M %p}", //12 hour format
    "format-alt": "п„і  {:%Y-%m-%d    пЂ— %H:%M:%S}",
    "interval": 1
  },

  // System
  "custom/system": {
    "format": "пЂ“",
    "tooltip": false
  },
  "cpu": {
    "format": "п‹› {usage: >3}%",
    "on-click": "ghostty -e htop"
  },
  "memory": {
    "format": "пѓ‰ {: >3}%",
    "on-click": "ghostty -e htop"
  },
  "temperature": {
    "thermal-zone": 4,
    // "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}В°C п‹‡",
    "format": "п‹‰  {temperatureC}В°C"
  },
  // Harddisc space used
  "disk": {
    // "interval": 30,
    "format": "п‚  {percentage_used}% ",
    "path": "/",
    //"on-click": "ghostty -e htop"
  }, 
    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory"
            // "backlight",
            //"sway/language"
        ]
    },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    // "format-icons": ["п†…", "п„‘"],
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-up": "brightnessctl -c backlight set +5%",
    // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
    "on-click": ""
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-charging": "п—§  {capacity}%",
    "format-plugged": "п‡¦  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format": "вљ   Disabled",
    "format-wifi": "п‡«  {essid}",
    // "format-ethernet": "пѓЃ {ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "пѓЃ  Wired",
    "format-disconnected": "вљ   Disconnected",
    "tooltip-format": "пћ– {ifname} via {gwaddri}",
    "tooltip-format-wifi": "п‡«   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пѓЃ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "вљ   Disconnected",
    // "on-click": "ghostty -e nmtui"
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    // "scroll-step": 5,
    "format": "{icon} {volume: >3}%",
    "format-bluetooth": "{icon} {volume: >3}%",
    "format-muted": "пљ© muted",
    "format-icons": {
      "headphones": "пЂҐ",
      "handsfree": "пЂҐ",
      "headset": "пЂҐ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": ["пЂ§", "пЂЁ"]
    },
    "on-click": "pavucontrol",
    // "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
    // "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob"
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },
  "custom/keyboard-layout": {
    "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
    // Interval set only as a fallback, as the value is updated by signal
    "interval": 1,
    "format": "п„њ  {}", // Icon: keyboard
    // Signal sent by Sway key binding (~/.config/sway/key-bindings)
    "signal": 1, // SIGHUP
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/keyhint.sh"
  }
}
